/* ===== COLORS for project cards ===== */
const CARD_COLORS=[
  '#d8e8d2','#cdd9e0','#e0d8cc','#d4e4ce','#cce4e0',
  '#e0d4cc','#d0dce8','#d8d4c8','#cce8d8','#d8cce0',
];
function cardColor(i){return CARD_COLORS[i%CARD_COLORS.length]}

/* ===== ROUTING ===== */
let currentPage='home';
let catTabState='';

function go(page,filter){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const el=document.getElementById('page-'+page);
  if(!el){console.warn('Page not found:',page);return;}
  el.classList.add('active');
  currentPage=page;
  window.scrollTo({top:0,behavior:'smooth'});
  closeMob();
  if(page==='home') renderPopGrid('дом-брус');
  if(page==='catalog') renderCatalog(filter||'');
  if(page==='gallery') initGallery(filter||'all');
}

/* ===== BURGER ===== */
function toggleMob(){
  document.getElementById('brgBtn').classList.toggle('open');
  document.getElementById('mobNav').classList.toggle('open');
}
function closeMob(){
  document.getElementById('brgBtn').classList.remove('open');
  document.getElementById('mobNav').classList.remove('open');
}

/* ===== GO TO FEEDBACK ===== */
function goFb(){
  if(currentPage==='home'){
    document.getElementById('home-fb').scrollIntoView({behavior:'smooth'});
  } else {
    const fb=document.querySelector('#page-'+currentPage+' .fb-section');
    if(fb) fb.scrollIntoView({behavior:'smooth'});
    else{ go('home'); setTimeout(()=>document.getElementById('home-fb').scrollIntoView({behavior:'smooth'}),400); }
  }
}

/* ===== HERO ===== */
let heroIdx=0;
const heroTotal=2;
function heroGo(d){heroSet((heroIdx+d+heroTotal)%heroTotal)}
function heroSet(i){
  heroIdx=i;
  document.getElementById('heroTrack').style.transform=`translateX(-${heroIdx*100}%)`;
  document.querySelectorAll('.h-dot').forEach((d,j)=>d.classList.toggle('active',j===heroIdx));
}
setInterval(()=>heroGo(1),5500);

/* ===== NEWS ===== */
let newsIdx=0;
function newsGo(d){
  const track=document.getElementById('newsTrack');
  const cards=track.querySelectorAll('.news-card');
  const visible=window.innerWidth<768?1:3;
  const max=Math.max(0,cards.length-visible);
  newsIdx=Math.max(0,Math.min(max,newsIdx+d));
  const w=cards[0].getBoundingClientRect().width+20;
  track.style.transform=`translateX(-${newsIdx*w}px)`;
}

/* ===== POP PROJECTS ===== */
function renderPopGrid(filter){
  const grid=document.getElementById('popGrid');
  if(!grid) return;
  let sub;
  if(filter==='дом-брус') sub=PROJECTS.filter(p=>p.type==='дом'&&p.mat==='брус').slice(0,4);
  else if(filter==='дом-бревно') sub=PROJECTS.filter(p=>p.type==='дом'&&p.mat==='бревно').slice(0,4);
  else if(filter==='баня-бревно') sub=PROJECTS.filter(p=>p.type==='баня'&&p.mat==='бревно').slice(0,4);
  else if(filter==='баня-брус') sub=PROJECTS.filter(p=>p.type==='баня'&&p.mat==='брус').slice(0,4);
  else sub=PROJECTS.slice(0,4);
  grid.innerHTML=sub.map((p,i)=>`
    <div class="proj-card" onclick="openProject('${p.id}')">
      <div class="proj-img" style="background:${cardColor(i)}">🏠<div style="font-size:11px;color:#555">${p.name}</div></div>
      <div class="proj-body">
        <div class="proj-name">${p.name}</div>
        <div class="proj-meta"><span>📐 ${p.sq} м²</span><span>🏠 ${p.fl} эт.</span></div>
        <div class="proj-desc">${p.desc}</div>
        <div class="proj-price">Цена: По запросу</div>
        <button class="proj-btn">Подробнее</button>
      </div>
    </div>`).join('');
}
function popFilter(f,btn){
  document.querySelectorAll('.pop-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderPopGrid(f);
}

/* ===== CATALOG ===== */
function renderCatalog(preFilter){
  // Полный сброс всех фильтров перед применением нового
  catTabState='';
  document.querySelector('input[name="ftype"][value=""]').checked=true;
  document.querySelectorAll('input[name="fmat"],input[name="fetazh"],input[name="fsq"]').forEach(c=>c.checked=false);
  document.querySelectorAll('.cat-tab').forEach((b,i)=>b.classList.toggle('active',i===0));

  if(preFilter){
    // Определяем тип (дом/баня)
    const isBanya=preFilter.startsWith('баня');
    const typeName=isBanya?'баня':'дом';
    catTabState=typeName;
    const typeEl=document.querySelector(`input[name="ftype"][value="${typeName}"]`);
    if(typeEl) typeEl.checked=true;

    // Определяем материал (бревно/брус) — только если он явно указан
    if(preFilter.endsWith('бревно')){
      const matEl=document.querySelector('input[name="fmat"][value="бревно"]');
      if(matEl) matEl.checked=true;
    } else if(preFilter.endsWith('брус')){
      const matEl=document.querySelector('input[name="fmat"][value="брус"]');
      if(matEl) matEl.checked=true;
    }

    // Синхронизируем вкладки-кнопки
    document.querySelectorAll('.cat-tab').forEach(b=>b.classList.remove('active'));
    if(isBanya) document.getElementById('ctBanya').classList.add('active');
    else document.getElementById('ctDom').classList.add('active');
  }
  applyFilter();
}

function catTab(type,btn){
  catTabState=type;
  document.querySelectorAll('.cat-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  // Sync radio
  const r=document.querySelector(`input[name="ftype"][value="${type}"]`);
  if(r) r.checked=true;
  applyFilter();
}

function applyFilter(){
  const matChecks=[...document.querySelectorAll('input[name="fmat"]:checked')].map(c=>c.value);
  const flChecks=[...document.querySelectorAll('input[name="fetazh"]:checked')].map(c=>+c.value);
  const sqChecks=[...document.querySelectorAll('input[name="fsq"]:checked')].map(c=>c.value);

  let res=PROJECTS;
  if(catTabState) res=res.filter(p=>p.type===catTabState);
  if(matChecks.length) res=res.filter(p=>matChecks.includes(p.mat));
  if(flChecks.length) res=res.filter(p=>flChecks.includes(p.fl));
  if(sqChecks.length) res=res.filter(p=>sqChecks.some(r=>{
    const[a,b]=r.split('-').map(Number);
    return p.sq>=a&&p.sq<=b;
  }));

  const grid=document.getElementById('catGrid');
  const countEl=document.getElementById('catCount');
  if(!grid) return;
  countEl.textContent=`Найдено: ${res.length}`;
  if(!res.length){
    grid.innerHTML='<div class="no-results">Проекты не найдены. Попробуйте изменить фильтры.</div>';
    return;
  }
  grid.innerHTML=res.map((p,i)=>`
    <div class="cat-card" onclick="openProject('${p.id}')">
      <div class="cat-img" style="background:${cardColor(i)}">🏠<div style="font-size:11px;color:#555;margin-top:3px">${p.name}</div></div>
      <div class="cat-body">
        <div class="cat-name">${p.name}</div>
        <div class="cat-meta">
          <span>📐 ${p.sq} м²</span>
          <span>🏠 ${p.fl} эт.</span>
          <span>${p.mat==='брус'?'🪵 Брус':'🌲 Бревно'}</span>
        </div>
        <div class="cat-desc">${p.desc}</div>
        <div class="cat-price">Цена: По запросу</div>
        <button class="cat-btn">Подробнее</button>
      </div>
    </div>`).join('');
}

function resetFilter(){
  document.querySelector('input[name="ftype"][value=""]').checked=true;
  document.querySelectorAll('input[name="fmat"],input[name="fetazh"],input[name="fsq"]').forEach(c=>c.checked=false);
  catTabState='';
  document.querySelectorAll('.cat-tab').forEach((b,i)=>b.classList.toggle('active',i===0));
  applyFilter();
}

/* ===== PROJECT DETAIL ===== */
let projIdx=0;
function openProject(id){
  const p=PROJECTS.find(x=>x.id===id);
  if(!p) return;
  document.getElementById('proj-bc-name').textContent=p.name;
  document.getElementById('proj-title').textContent=
    `${p.name} — ${p.type==='баня'?'Баня':'Дом'} из ${p.mat==='брус'?'профилированного бруса':'оцилиндрованного бревна'}`;
  document.getElementById('pd-sq').textContent=p.sq+' м²';
  document.getElementById('pd-fl').textContent=p.fl+(p.fl===1?' этаж':' этажа');
  document.getElementById('pd-desc').textContent=p.desc;
  // Reset slider & tabs
  projIdx=0;
  document.getElementById('projSliderTrack').style.transform='translateX(0)';
  document.querySelectorAll('#projDots .sdot').forEach((d,i)=>d.classList.toggle('active',i===0));
  document.querySelectorAll('#projThumbs .thumb').forEach((d,i)=>d.classList.toggle('active',i===0));
  document.querySelectorAll('.tab-btn').forEach((b,i)=>b.classList.toggle('active',i===0));
  document.querySelectorAll('.tab-pane').forEach((p,i)=>p.classList.toggle('active',i===0));
  document.querySelectorAll('.gal-tab').forEach((t,i)=>t.classList.toggle('active',i===0));
  go('project');
}

function projGo(d){
  projIdx=Math.max(0,Math.min(4,projIdx+d));
  document.getElementById('projSliderTrack').style.transform=`translateX(-${projIdx*100}%)`;
  document.querySelectorAll('#projDots .sdot').forEach((d,i)=>d.classList.toggle('active',i===projIdx));
  document.querySelectorAll('#projThumbs .thumb').forEach((d,i)=>d.classList.toggle('active',i===projIdx));
}
function projJump(i){projGo(i-projIdx)}

function galTabClick(type,btn){
  document.querySelectorAll('.gal-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  projJump(type==='plan'?3:0);
}

function tabSwitch(id,btn){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(id).classList.add('active');
}

/* ===== GALLERY ===== */
const GAL_CATS=['doma','doma','doma','doma','bani','bani','bani','bani','prochee','prochee',
  'doma','doma','doma','doma','bani','bani','bani','bani','doma','doma',
  'doma','bani','bani','prochee','doma','doma','bani','bani','doma','doma',
  'bani','doma','doma','bani','bani','doma','prochee','doma','bani','bani',
  'doma','doma','bani','bani','doma','doma','doma','bani','doma','bani',
  'doma','bani','bani','prochee'];
const GAL_COLORS=['#d8e8d2','#cdd9e0','#e0d8cc','#d8ddd2','#cce0e0','#e0d4cc','#d0dce8','#d8d4c8'];
let galCat='all', galVisible=20;

function initGallery(cat){
  galCat=cat;
  galVisible=20;
  document.querySelectorAll('.gal-fbtn').forEach(b=>{
    const oc=b.getAttribute('onclick')||'';
    b.classList.toggle('active',oc.includes(`'${cat}'`));
  });
  renderGallery();
}
function galFilter(cat,btn){
  galCat=cat; galVisible=20;
  document.querySelectorAll('.gal-fbtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderGallery();
}
function renderGallery(){
  const all=GAL_CATS.map((c,i)=>({i,c}));
  const filtered=galCat==='all'?all:all.filter(x=>x.c===galCat);
  const shown=filtered.slice(0,galVisible);
  const grid=document.getElementById('galleryGrid');
  const lab={doma:'🏠 Дом',bani:'🛁 Баня',prochee:'🏗️ Прочее'};
  grid.innerHTML=shown.map(({i,c})=>
    `<div class="gal-item" style="background:${GAL_COLORS[i%GAL_COLORS.length]}">
      <div>${lab[c]||'📸'}</div>
      <div style="font-size:11px;font-weight:400;color:var(--gray-text)">Объект #${i+1}</div>
    </div>`).join('');
  const btn=document.getElementById('showMoreBtn');
  btn.style.display=shown.length<filtered.length?'block':'none';
}
function galShowMore(){galVisible+=16;renderGallery()}

/* ===== FORM ===== */
function submitFb(cityId,phoneId){
  const city=document.getElementById(cityId)?.value||'';
  const phone=document.getElementById(phoneId)?.value?.trim()||'';
  if(!city){alert('Пожалуйста, выберите город.');return;}
  if(!phone){alert('Пожалуйста, введите номер телефона.');return;}
  alert(`✅ Форма отправлена (демо)\n\nГород: ${city}\nТелефон: ${phone}\n\nСпасибо! Мы свяжемся с вами в ближайшее время.`);
}

